<?xml version="1.0"?>

<robot name="AT-AT_w">

    <link name="base_footprint">
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </link>


    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.8 1 0.5"/> 
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="dark grey">
                <color rgba="0.42 0.42 0.42 1" />
            </material>
        </visual>
    </link>


    <joint name="base_footprint_base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 1.25" rpy="0 0 0"/>
    </joint>


    <link name="neck_link">
        <visual>
            <geometry>
                <cylinder length="0.25" radius="0.15"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 1.57075 1.57075"/>
            <material name="light grey">
                <color rgba="0.79 0.79 0.79 1" />
            </material>
        </visual>
    </link>


    <joint name="base_neck_joint" type="fixed">
        <parent link="base_link"/>
        <child link="neck_link"/>
        <origin xyz="0 -0.62 -0.05" rpy="0 0 0"/>
    </joint>


    <link name="head_link">
        <visual>
            <geometry>
                <box size="0.4 0.5 0.35"/> 
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="dark grey" />
        </visual>
    </link>


    <joint name="neck_head_joint" type="fixed">
        <parent link="neck_link"/>
        <child link="head_link"/>
        <origin xyz="0 -0.37 0.02" rpy="0 0 0"/>
    </joint>


    <link name="eye_left_link">
        <visual>
            <geometry>
                <cylinder length="0.025" radius="0.1"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 1.57075 1.57075"/>
            <material name="light grey" />
        </visual>
    </link>


    <joint name="head_eye_left_joint" type="fixed">
        <parent link="head_link"/>
        <child link="eye_left_link"/>
        <origin xyz="0.21 -0.1 0" rpy="0 0 1.57057"/>
    </joint>
    

    <link name="eye_right_link">
        <visual>
            <geometry>
                <cylinder length="0.025" radius="0.1"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 1.57075 1.57075"/>
            <material name="light grey" />
        </visual>
    </link>


    <joint name="head_eye_right_joint" type="fixed">
        <parent link="head_link"/>
        <child link="eye_right_link"/>
        <origin xyz="-0.21 -0.1 0" rpy="0 0 1.57057"/>
    </joint>


    <link name="shooter_left_link">
        <visual>
            <geometry>
                <cylinder length="0.15" radius="0.0125"/>
            </geometry>
            <origin xyz="0 0.15 0" rpy="0 1.57075 1.57075"/>
            <material name="dark grey" />
        </visual>
    </link>


    <joint name="eye_left_shooter_joint" type="revolute">
        <limit effort="100" velocity="1.0" lower="-1.0" upper="0"/>
        <parent link="eye_left_link"/>
        <child link="shooter_left_link"/>
        <origin xyz="0 0 0" rpy="0 0 1.57057"/>
        <axis xyz="1 0 0" rpy="0 0 0"/>
